# Copy this file to server/.env, or export these values in your shell before running the server.

# MongoDB connection string.
# The server defaults to a local instance if this is unset, so for local Docker you can leave it as is.
MONGODB_URI=mongodb://localhost:27017

# Origin allowed to call the API with credentials. Defaults to the Vite dev server.
CLIENT_ORIGIN=http://localhost:5173
